cask "wireshark-app"          # GUI packet analyzer (post-rename token; cask "wireshark" is the wrong deprecated form)
brew "wireshark"              # CLI tools: tshark (headless capture/filter) + editcap (format conversion)
brew "jadx"                   # Decompile WHOOP Android APK to Java; ships both jadx (CLI) and jadx-gui
cask "android-platform-tools" # Official Google adb + fastboot (bugreport extraction, adb pull APK)
brew "libimobiledevice"       # ideviceinfo + idevice_id: read iPhone firmware version + UDID without jailbreak
brew "openjdk"                # JRE 11+ that JADX requires (keg-only — brew prints the PATH/JAVA_HOME caveat on install)
brew "blueutil"               # Optional Mac Bluetooth CLI: toggle BT power, list devices, repeatable capture setup
