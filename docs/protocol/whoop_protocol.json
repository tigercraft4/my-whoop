            {"off": 44, "len": 4, "dtype": "f32", "name": "gravity_y", "cat": "accel", "note": "g"},
            {"off": 48, "len": 4, "dtype": "f32", "name": "gravity_z", "cat": "accel", "note": "g"},
            {"off": 55, "len": 1, "dtype": "u8", "name": "skin_contact", "cat": "contact", "note": "0=off-wrist"},
            {"off": 56, "len": 4, "dtype": "f32", "name": "gravity2_x", "cat": "accel", "note": "2nd accel/gravity triplet (g)"},
            {"off": 60, "len": 4, "dtype": "f32", "name": "gravity2_y", "cat": "accel", "note": "2nd accel/gravity triplet (g)"},
            {"off": 64, "len": 4, "dtype": "f32", "name": "gravity2_z", "cat": "accel", "note": "2nd accel/gravity triplet (g)"},
            {"off": 68, "len": 2, "dtype": "u16", "name": "spo2_red", "cat": "spo2", "note": "raw ADC; SpO2 % computed server-side"},
            {"off": 70, "len": 2, "dtype": "u16", "name": "spo2_ir", "cat": "spo2", "note": "raw ADC; SpO2 % computed server-side"},
            {"off": 72, "len": 2, "dtype": "u16", "name": "skin_temp_raw", "cat": "temp", "note": "raw ADC; degC computed server-side"},
            {"off": 74, "len": 2, "dtype": "u16", "name": "ambient", "cat": "optical", "note": "ambient light ADC"},
            {"off": 76, "len": 2, "dtype": "u16", "name": "led_drive_1", "cat": "optical"},
            {"off": 78, "len": 2, "dtype": "u16", "name": "led_drive_2", "cat": "optical"},
            {"off": 80, "len": 2, "dtype": "u16", "name": "resp_rate_raw", "cat": "resp", "note": "raw; resp rate computed server-side"},
            {"off": 82, "len": 2, "dtype": "u16", "name": "signal_quality", "cat": "quality"}
          ],
          "rr_first_off": 23,
          "note": "V24 (this WHOOP 4.0). Verified on 762 device records: HR 57-70, |gravity|~1g. Raw ADCs (SpO2/temp/resp) are NOT converted client-side; WHOOP computes them in cloud."
        },
        "12": {"kind": "biometric", "ref": "24", "note": "V12 = same DSP layout as V24 (openwhoop)."},
        "5": {"kind": "generic", "fields": [
            {"off": 11, "len": 4, "dtype": "u32", "name": "unix", "cat": "time"},
            {"off": 21, "len": 1, "dtype": "u8", "name": "heart_rate", "cat": "hr", "note": "bpm"},
            {"off": 22, "len": 1, "dtype": "u8", "name": "rr_count", "cat": "rr"}
          ], "rr_first_off": 23, "note": "Generic HR/RR-only record (no DSP sensor block)."},
        "7": {"kind": "generic", "ref": "5"},
        "9": {"kind": "generic", "ref": "5"}
      }
    },
