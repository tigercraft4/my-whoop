      "variants": {
        "1917": {
          "kind": "imu",
          "hr_off": 21, "rr_count_off": 22, "rr_first_off": 23,
          "samples": 100,
          "axes": [["accelX", 89, "accel"], ["accelY", 289, "accel"], ["accelZ", 489, "accel"],
                   ["gyroX", 692, "gyro"], ["gyroY", 892, "gyro"], ["gyroZ", 1092, "gyro"]],
          "accel_scale": 0.000244140625,
          "accel_unit": "g",
          "gyro_scale": 0.06103515625,
          "gyro_unit": "deg/s",
          "tail_from": 1292,
          "note": "Gen4-VERIFIED (motion_capture.jsonl + gyro_calib 720deg rotations): 100 samples/axis @~100Hz (1 pkt/s), signed int16 LITTLE-endian. ACCEL scale 1/4096 LSB/g (sphere-fit |g|=0.99, residual 0.0%). GYRO scale 2000/32768 = 0.06104 deg/s/LSB = full-scale +/-2000 dps (16.4 LSB per deg/s); verified via controlled 720deg rotation (rotA = exact 16.4 LSB/dps; +/-~10% from turn-count precision). openwhoop's div-15 (0.0667) is within tolerance. Gaps [24:82],[682:685] + tail [1292:1917] (~36%) still unmapped."
        },
        "1921": {
          "kind": "optical",
          "ppg_off": 42, "ppg_stride": 4, "ppg_dtype": "s24", "ppg_samples": 419, "ppg_rate_hz": 437,
          "config_from": 15, "config_to": 42,
          "note": "Gen4-RE (optical_capture.jsonl): a SINGLE AC-coupled (DC-removed) PPG waveform, NOT 4 interleaved channels. Sample @ frame off 42, stride 4, bytes[0:3]=signed 24-bit LE, byte[3]=aux (status/exposure, UNKNOWN). ~419 samples/pkt @~437Hz. Finger phase = clean ~1Hz pulsatile (=green/HR LED); air phase flatlines. Red/IR/ambient NOT in this stream (only as DSP'd scalars in type-47 V24). Config header [15:42] and byte[3] UNKNOWN -> keep raw for those."
        }
      }
    },
    "HISTORICAL_DATA": {
      "type": 47, "post": "historical_data",
      "fields": [],
      "note": "The 14-day biometric store. Version = seq byte (frame[5]). Reachable only via the high-freq-sync handshake + valid RTC. Field offsets below are FRAME-absolute (= openwhoop data offset + 7).",
      "versions": {
        "24": {
          "kind": "biometric",
          "fields": [
            {"off": 11, "len": 4, "dtype": "u32", "name": "unix", "cat": "time", "note": "real unix seconds"},
            {"off": 21, "len": 1, "dtype": "u8", "name": "heart_rate", "cat": "hr", "note": "bpm"},
